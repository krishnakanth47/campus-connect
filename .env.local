# Campus Connect Environment Variables

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/campus_connect

# JWT Secret (change this in production!)
JWT_SECRET=campus_connect_super_secret_jwt_key_2024_hackathon

# Next.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=campus_connect_nextauth_secret

# GitHub API (optional - for higher rate limits)
GITHUB_TOKEN=

# App
NODE_ENV=development
PORT=3000
